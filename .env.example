# 容器构建参数（需要在执行 docker compose build 前覆盖时再取消注释）
# 示例：NODE_VERSION=22
# 示例：PYTHON_VERSION=3.13

# 容器运行时参数
PUID=1000
PGID=1000
ANI_COL_ROOT_DIR=./runtime
# 容器编排会读取这个运行时 .env 文件，并把其中的变量注入到容器环境变量中。
# 当前不会把这个文件作为卷挂载到容器内；应用读取的是注入后的环境变量。
# 示例：ANI_COL_ENV_FILE=./runtime/.env

# 本地开发共用默认值
ANI_COL_HOST=0.0.0.0
ANI_COL_PORT=8001
ANI_COL_RELOAD=true

# 前端开发服务器（Vite）
VITE_DEV_SERVER_PORT=5173

# 可选：仅当前端需要直接访问一个非默认后端地址时再覆盖。
# 示例：VITE_API_BASE_URL=http://localhost:8001

