# Docker / compose runtime
PUID=1000
PGID=1000
ANI_COL_ROOT_DIR=./runtime

# Shared local development defaults
ANI_COL_HOST=0.0.0.0
ANI_COL_PORT=8060
ANI_COL_RELOAD=true

# Vite dev server
VITE_DEV_SERVER_PORT=5173

# Optional: override only when the frontend should call a non-default backend URL directly.
# VITE_API_BASE_URL=http://localhost:8060

